{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "louisbrowne",
  "pages_build_output_dir": ".open-next/assets",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}